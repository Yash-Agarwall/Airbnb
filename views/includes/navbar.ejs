<style>
  .navbar {
    min-height: 4.25rem;
    height: auto;
    background-color: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(140%) blur(3px);
    box-shadow: 0 4px 18px rgba(34, 34, 34, 0.05);
  }

  .navbar .container-fluid {
    max-width: 1320px;
    margin: 0 auto;
    padding-left: 1.1rem;
    padding-right: 1.1rem;
  }

  .navbar-brand i {
    font-size: 1.35rem;
  }

  .navbar-center {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .nav-left,
  .nav-links-right {
    flex: 1;
    align-items: center;
    gap: 0.2rem;
  }

  .nav-links-right {
    justify-content: flex-end;
  }

  .nav-link {
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    transition: background-color 180ms ease, color 180ms ease;
  }

  .nav-link:hover {
    background-color: #f5f5f5;
  }

  .search-wrap {
    width: 100%;
    max-width: 400px;
    margin: 0.35rem auto;
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .search-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 999px;
    border: 1px solid #fe424d;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.44rem 0.92rem;
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1;
    box-shadow: 0 6px 14px rgba(254, 66, 77, 0.2);
  }

  .search-btn:hover {
    background-color: #e53743;
    border-color: #e53743;
    color: #fff;
    transform: translateY(-1px);
  }

  .search-btn i {
    display: inline;
    margin-right: 0.35rem;
    font-size: 0.86rem;
  }

  .search-inp {
    border-radius: 999px;
    padding: 0.42rem 0.95rem;
    font-size: 0.92rem;
    border: 1px solid #dddddd;
    background: #fff;
  }

  .search-inp::placeholder {
    color: #7c8188;
  }

  .search-inp:focus {
    border-color: #a8adb4;
    box-shadow: 0 0 0 0.15rem rgba(34, 34, 34, 0.08);
  }

  @media (max-width: 991.98px) {
    .navbar .container-fluid {
      padding-left: 0.9rem;
      padding-right: 0.9rem;
    }

    .navbar-center,
    .nav-left,
    .nav-links-right {
      flex: initial;
      width: 100%;
      justify-content: flex-start;
    }

    .search-wrap {
      max-width: 100%;
      margin: 0.65rem 0;
    }

    .nav-links-right {
      gap: 0.25rem;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav nav-left">
        <a class="nav-link" href="/listings">Explore</a>
      </div>
      <div class="navbar-center">
        <div class="search-wrap">
          <form class="search-form" role="search" action="/listings" method="GET">
            <input
              class="form-control search-inp"
              type="search"
              name="q"
              placeholder="Search destinations"
              aria-label="Search destinations"
            >
            <button class="btn search-btn" type="submit">
              <i class="fa-solid fa-magnifying-glass"></i>Search
            </button>
          </form>
        </div>
      </div>
      <div class="navbar-nav nav-links-right">
        <a class="nav-link" href="/listings/new">Rent Home</a>
        <% if(!currUser) { %>
        <a class="nav-link" href="/signup"><b>Sign Up</b></a>
        <a class="nav-link" href="/login"><b>Login</b></a>
        <% } else { %>
        <a class="nav-link" href="/logout"><b>Logout</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>