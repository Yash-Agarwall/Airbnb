<% layout("layouts/boilerplate") %>
<%= success %>
<h1 class="mb-4">All Listings</h1>

<!-- <form method="GET" action="/listings/new" class="mb-4">
    <button class="btn btn-dark">Create New Listing</button>
</form> -->
<div class="row row-cols-lg-3 row row-cols-md-2 row row-cols-sm-1">
<% for (let listing of allListings) { %>
    <a class="listing-link" href="/listings/<%= listing._id %>">
        <div class="card col" >
        <img src="<%= listing.image.url%>" class="card-img-top" alt="..." style="height: 20rem; ">
        <div class="card-img-overlay"></div>
            <div class="card-body">
                <p class="card-text"><%= listing.title %>
                <br>&#8377;<%= listing.price.toLocaleString("en-IN")%>/night</p>
            </div>
        </div>       
    </a>
<% } %>
</div>
