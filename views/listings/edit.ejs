<% layout("layouts/boilerplate") %>

<h3 class="mb-3">Edit Listing</h3>
<form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
  <input class="form-control mb-3" name="listing[title]" value="<%= listing.title %>" type="text" required />
  <textarea class="form-control mb-3" name="listing[description]"><%= listing.description %></textarea>
  <input class="form-control mb-3" name="listing[image][url]" value="<%= listing.image && listing.image.url ? listing.image.url : '' %>" type="text" />
  <input class="form-control mb-3" name="listing[price]" value="<%= listing.price %>" type="number" min="0" />
  <input class="form-control mb-3" name="listing[country]" value="<%= listing.country %>" type="text" />
  <input class="form-control mb-3" name="listing[location]" value="<%= listing.location %>" type="text" />
  <button class="btn btn-dark">Save Changes</button>
</form>