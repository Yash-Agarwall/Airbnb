<% layout("/layouts/boilerplate") %>

<div class="show-shell">
  <section class="show-hero card">
    <% if (listing.image && listing.image.url) { %>
      <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="show-hero-image" />
    <% } %>
    <div class="show-hero-content">
      <p>Onwer: <%= listing.owner.username %></p>
      <p class="show-kicker">Stay Details</p>
      <h1 class="show-title"><%= listing.title %></h1>
      <p class="show-location"><%= listing.location %>, <%= listing.country %></p>
      <div class="show-price-tag">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</div>
      <p class="show-description"><%= listing.description %></p>

      <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
      <div class="show-actions">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit Listing</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
          <button class="btn btn-outline-danger">Delete Listing</button>
        </form>
      </div>
      <% } %>
    </div>
  </section>

  <section class="review-layout">
    <div class="card review-form-card">
      <!-- here we ahve to make sure that the usr is logged in, for that just check if currUser exists -->
      <% if(currUser) {%>
      <div class="card-body p-4">
        <h4 class="mb-3">Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
          <div class="mb-3 mt-3">
            <label class="form-label d-block">Rating</label>
            <fieldset class="starability-slot review-rating-group">
              <input type="radio" id="first-rate5" name="review[rating]" value="5" required />
              <label for="first-rate5" title="Amazing">5 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
            </fieldset>
            <div class="text-danger small mt-1 d-none rating-error">Please choose a rating before submitting.</div>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" rows="4" class="form-control" placeholder="Share your experience..." required></textarea>
            <div class="invalid-feedback">Please add a comment before submitting.</div>
          </div>
          <button class="btn btn-dark px-4" id="reviewSubmitBtn" disabled>Post Review</button>
        </form>
      </div>
      <% } %>
    
    </div>

    <% if(listing.reviews.length>0) { %>
    <div class="card review-list-card">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h4 class="mb-0">Guest Reviews</h4>
          <span class="review-count"><%= listing.reviews.length %> total</span>
        </div>

        <% if (listing.reviews.length === 0) { %>
          <p class="text-muted mb-0">No reviews yet. Be the first to share feedback.</p>
        <% } %>

        <% for (let review of listing.reviews) { %>
          <article class="review-item">
            <p class="text-muted mb-1">By: <%= review.author ? review.author.username : "Anonymous" %></p>
            <div class="review-item-head">
              <p class="review-rating mb-1">
                <span class="starability-result" data-rating="<%= review.rating %>">
                  Rated: <%= review.rating %> stars
                </span>
              </p>
              <span class="review-score"><%= review.rating %>/5</span>
            </div>
            <p class="review-comment mb-0"><%= review.comment %></p>
            <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
            <form action="/listings/<%= listing._id %>/reviews/<%= review._id%>?_method=DELETE" method="post">
              <button>Delete</button>
            </form>
            <% } %>
          </article>
        <% } %>
      </div>
    </div>
    <% } %>
  </section>
  </div>
</div>
